{
  "name": "@fareyetechnologies/label-generation-frontend",
  "version": "v1.3.7",
  "private": false,
  "main": "lib/cjs",
  "module": "lib/esm",
  "repository": {
    "type": "git",
    "url": "https://github.com/FarEyeTechnologies/label-generation-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@ant-design/icons": "^4.7.0",
    "ace-builds": "^1.4.14",
    "react-ace": "^9.5.0",
    "web-vitals": "^1.0.1",
    "styled-components": "^5.3.6",
    "antd": "5.4.0",
    "axios": "^1.6.3",
    "react-localization": "^1.0.10"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "concurrently yarn:build:*",
    "build:esm": "cross-env BABEL_ENV=esm babel src --extensions .ts,.tsx,.js -d lib/esm --source-maps && cp -r src/images lib/cjs && cp -r src/CSS lib/cjs",
    "build:cjs": "cross-env BABEL_ENV=cjs babel src --extensions .ts,.tsx,.js -d lib/cjs --source-maps && cp -r src/images lib/esm && cp -r src/CSS lib/esm",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "publish:npm": "rm -rf dist && mkdir dist &&  babel src -d dist --copy-files && cp package.json dist/"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "devDependencies": {
    "@babel/cli": "^7.14.3",
    "@babel/core": "^7.11.1",
    "@babel/preset-env": "^7.14.4",
    "@babel/preset-react": "^7.13.13",
    "@babel/plugin-proposal-class-properties": "^7.10.4",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.16.5",
    "@babel/preset-typescript": "^7.10.4",
    "babel-loader": "8.2.2",
    "concurrently": "^5.2.0",
    "cross-env": "^7.0.2",
    "mini-css-extract-plugin": "^0.8.0",
    "react-hot-loader": "^4.5.3"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.20.1"
  },
  "files": [
    "lib"
  ]
}
